generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User role enum
enum UserRole {
  USER
  ADMIN
  EMPLOYEE
  SUPPORT
}

enum EmployeeCountry {
  GB
  US
  CN
  IT
  GR
  ES
  FR
  DE
  TR
}

enum ChatSender {
  USER
  ADMIN
}

// User model for authentication and user management
model User {
  id               String           @id @default(cuid())
  email            String           @unique
  password         String
  firstName        String?
  lastName         String?
  phone            String?          @unique
  phoneVerified    Boolean          @default(false)
  personalIdNumber String           @unique
  city             String?
  address          String?
  /// საფოსტო ინდექსი (4 ციფრი, საქართველო)
  postalIndex      String?
  termsAcceptedAt  DateTime?
  balance          Float            @default(0) // მომხმარებლის ბალანსი (GEL)
  roomNumber       String?          @unique // მომხმარებლის ოთახის ნომერი (მაგ. PO1, PO2, PO3...)
  role             UserRole         @default(USER)
  employeeCountry  EmployeeCountry?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  addresses      Address[]
  parcels        Parcel[]
  /// ამანათები, რომლებიც ამ მომხმარებელმა (ადმინი/თანამშრომელი) შექმნა სისტემაში
  parcelsCreated Parcel[]      @relation("ParcelCreatedBy")
  payments       Payment[]
  orders         Order[]
  chats          ChatThread[]
  declarations   Declaration[]

  @@map("users")
}

// Temporary OTP codes for phone verification (registration)
model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String // normalized international format (e.g. 995599...)
  code      String // 4-digit OTP
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("phone_otps")
}

// Address model for shipping addresses
model Address {
  id         String   @id @default(cuid())
  userId     String
  type       String // "shipping" | "billing" | "pickup"
  country    String
  city       String
  street     String
  building   String?
  apartment  String?
  postalCode String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcels Parcel[]

  @@map("addresses")
}

// Parcel model for packages/shipments
enum ParcelStatus {
  pending
  in_warehouse
  in_transit
  arrived
  region
  ready_for_pickup
  delivered
  stopped
  cancelled
}

model Parcel {
  id             String       @id @default(cuid())
  userId         String
  trackingNumber String       @unique
  status         ParcelStatus @default(pending)

  // Required for creation
  customerName String // მომხმარებლის სახელი
  price        Float // ნაყიდი ნივთის ღირებულება (რამდენი ღირდა)
  onlineShop   String // ონლაინ მაღაზია
  quantity     Int // ამანათის რაოდენობა
  comment      String? // კომენტარი (optional)

  // Origin information
  originCountry String?
  originAddress String?

  // Destination information
  destinationAddressId String?

  // Package details
  weight           Float? // in kg
  volumetricWeight Float? // in kg
  length           Float? // in cm
  width            Float? // in cm
  height           Float? // in cm
  description      String?

  // Pricing
  currency       String  @default("GEL")
  shippingAmount Float? // გადასახდელი (წონა × ტარიფი) - რას გადაიხდის მომხმარებელი
  filePath       String? // stored path to uploaded declaration PDF (optional)

  // Customs
  customsValue    Float?
  customsDeclared Boolean @default(false)

  /// მომხმარებლის მიერ მონიშნული საკურიერო (UI მხოლოდ status=arrived)
  courierServiceRequested Boolean @default(false)
  /// ადმინის მიერ დაყენებული საკურიერო გადასახადი (მომხმარებელი ხედავს და იხდის)
  courierFeeAmount        Float?
  /// ჩამოსულისთვის ადმინის მიერ დაყენებული ძირითადი გადასახდელი (სავალდებულო გადახდის თანხა)
  payableAmount           Float?
  /// ბოლო სტატუსის SMS წარმატებით გაიგზავნა თუ არა (მფლობელის ტელეფონზე)
  smsSent                 Boolean @default(false)

  // Dates
  shippedAt   DateTime?
  arrivedAt   DateTime?
  readyAt     DateTime?
  deliveredAt DateTime?
  reisId      String?
  /// ვინ დაამატა ამანათი (ადმინი/თანამშრომელი); მომხმარებლის თვითდამატებისას null
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("ParcelCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  address   Address?   @relation(fields: [destinationAddressId], references: [id])
  reis      Reis?      @relation(fields: [reisId], references: [id], onDelete: SetNull)
  tracking  Tracking[]
  payments  Payment[]
  order     Order?

  @@index([userId])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([status, originCountry, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([status, originCountry, createdAt(sort: Desc), id(sort: Desc)])
  @@index([createdById])
  @@map("parcels")
}

// Tracking model for tracking updates
model Tracking {
  id          String   @id @default(cuid())
  parcelId    String
  status      String
  location    String?
  description String?
  createdAt   DateTime @default(now())

  parcel Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@map("trackings")
}

// Payment model for payment records
model Payment {
  id            String   @id @default(cuid())
  userId        String
  parcelId      String?
  orderId       String?
  amount        Float
  currency      String   @default("GEL")
  status        String   @default("pending") // "pending" | "completed" | "failed" | "refunded"
  paymentMethod String // "card" | "bank_transfer" | "balance"
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcel Parcel? @relation(fields: [parcelId], references: [id])

  @@map("payments")
}

// Order model for service orders
model Order {
  id          String   @id @default(cuid())
  userId      String
  parcelId    String?  @unique
  type        String // "forwarding" | "customs" | "courier" | "corporate"
  status      String   @default("pending") // "pending" | "processing" | "completed" | "cancelled"
  totalAmount Float
  currency    String   @default("GEL")
  weight      String   @default("") // წონა (kg)
  smsSent     Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcel Parcel? @relation(fields: [parcelId], references: [id])

  @@map("orders")
}

// Tariff model for pricing information
model Tariff {
  id                 String   @id @default(cuid())
  originCountry      String
  destinationCountry String   @default("GE")
  minWeight          Float    @default(0)
  maxWeight          Float?
  pricePerKg         Float
  currency           String   @default("GEL")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive, destinationCountry])
  @@map("tariffs")
}

// Branch model for pickup points
model Branch {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String
  country      String   @default("GE")
  phone        String?
  email        String?
  latitude     Float?
  longitude    Float?
  workingHours String? // JSON string or formatted text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("branches")
}

// Reis model for grouping shipments/trips (e.g. customs flights)
model Reis {
  id                 String    @id @default(cuid())
  name               String
  originCountry      String
  destinationCountry String    @default("GE")
  departureAt        DateTime?
  arrivalAt          DateTime?
  status             String    @default("open") // open | closed
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  parcels Parcel[]

  @@map("reises")
}

// Chat between external user and admin
model ChatThread {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String
  status    String   @default("open") // open | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  messages ChatMessage[]

  @@map("chat_threads")
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  sender    ChatSender
  text      String
  createdAt DateTime   @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// Customs declaration submitted by user
model Declaration {
  id           String   @id @default(cuid())
  userId       String
  firstName    String
  lastName     String
  trackingCode String
  price        Float
  currency     String   @default("GEL")
  filePath     String // stored path to uploaded PDF
  status       String   @default("pending") // pending | processed | rejected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("declarations")
}
